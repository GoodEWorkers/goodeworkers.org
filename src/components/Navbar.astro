---
import logoSvg from '../assets/images/goodeworkers.svg?raw';
import Hamburger from './Miscs/Hamburger.astro';

const navbarTextContact = 'Contact';
const navbarTextMenu = 'Menu';
---

<div class="bg-black sticky inset-x-0 top-0 lg:mt-16 z-50" data-navbar>
  <nav
    class="relative flex justify-between items-center font-inter max-w-screen-2xl mx-auto px-4 md:px-8 pt-2 pb-2 md:pt-4 md:pb-4 text-grey"
  >
    <a href="/" aria-label="Good eWorkers home">
      <span
        class="inline-block w-[110px] h-[44px] md:w-[160px] md:h-[63px] [&>svg]:w-full [&>svg]:h-full"
        set:html={logoSvg}
      />
    </a>
    <ul class="hidden md:flex md:space-x-12 font-bold">
      <li>
        <a
          href="/#contact"
          class="border-orange border-2 -ml-2 px-2 py-px rounded-full hover:bg-orange hover:text-black transition-colors duration-200"
        >
          {navbarTextContact}
        </a>
      </li>
    </ul>
    <button
      type="button"
      class="md:hidden relative z-50"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="sr-only">{navbarTextMenu}</span>
      <Hamburger />
    </button>
    <div
      id="mobile-menu"
      class="hidden md:hidden absolute top-0 inset-x-0 z-40 mobile-menu"
      data-menu-panel
    >
      <ul class="bg-black h-screen text-white font-bold text-xl pt-12">
        <li class="pl-16 pr-4 py-3">
          <a
            href="/#contact"
            class="hover:text-orange block w-full h-full"
            data-menu-link
          >
            {navbarTextContact}
          </a>
        </li>
      </ul>
    </div>
  </nav>
</div>

<style>
  .mobile-menu {
    transition: opacity 100ms ease-in, transform 100ms ease-in;
    transform: translateY(-0.5rem);
    opacity: 0;
  }
  .mobile-menu.is-open {
    transform: translateY(0);
    opacity: 1;
  }
</style>

<script>
  function setupNavbar() {
    const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
    const hamburger = document.querySelector<HTMLElement>('[data-hamburger]');
    if (!toggle || !panel || !hamburger) return;

    const close = () => {
      panel.classList.add('hidden');
      panel.classList.remove('is-open');
      hamburger.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
    };
    const open = () => {
      panel.classList.remove('hidden');
      // next frame to allow transition
      requestAnimationFrame(() => panel.classList.add('is-open'));
      hamburger.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
    };

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? close() : open();
    });

    panel.querySelectorAll<HTMLAnchorElement>('[data-menu-link]').forEach((a) => {
      a.addEventListener('click', () => close());
    });
  }

  setupNavbar();
  document.addEventListener('astro:page-load', setupNavbar);
</script>
