---
interface Props {
  text: string;
  class?: string;
}

const { text, class: className } = Astro.props;
---

<span class="relative"><span class={`z-10 relative px-1.5 ${className ?? ''}`}>{text}</span><span class="absolute inset-x-0 top-[25%] rounded-full z-0 border-orange border md:border-2 h-[62%]"></span></span>
