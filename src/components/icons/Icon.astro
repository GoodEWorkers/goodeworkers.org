---
interface Props {
  name:
    | 'calendar'
    | 'chat'
    | 'dollar'
    | 'heart'
    | 'hexagone'
    | 'lili'
    | 'magnify'
    | 'map'
    | 'webnet';
}

const { name } = Astro.props;

const icons = import.meta.glob<string>('../../assets/icons/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const svg = icons[`../../assets/icons/${name}.svg`];
---

<Fragment set:html={svg} />
