---
import ContactForm from './ContactForm.astro';

const currentYear = new Date().getFullYear();
const goodEWorkersEmail = 'hello@goodeworkers.org';
const goodEWorkersText1 = 'hello';
const goodEWorkersText2 = '@goodeworkers.org';
const goodEWorkersText3 = `GoodEWorkers © ${currentYear}`;
const goodEWorkersText4 = 'Legal Notice | Mentions légales';
---

<footer class="relative z-10 bg-white text-black font-inter">
  <div
    class="absolute -z-50 bg-transparent w-px h-px transform -translate-y-12"
    id="contact"
  >
  </div>
  <div class="max-w-screen-2xl mx-auto px-4 md:px-8 mb-4 pt-12 pb-10">
    <div class="flex flex-col">
      <p class="text-xs font-bold">Contact-us !</p>
      <div class="mt-4">
        <a href={`mailto:${goodEWorkersEmail}`} class="text-3xl font-bold">
          {goodEWorkersText1}<br />{goodEWorkersText2}
        </a>
      </div>
      <ContactForm />
    </div>
    <ul
      class="mt-24 md:mt-40 xl:mt-60 flex flex-col items-center text-sm space-y-2"
    >
      <li class="hover:underline">
        <a href="/legal-notice">{goodEWorkersText4}</a>
      </li>
      <li>
        This site is powered by <a
          class="hover:underline"
          href="https://netlify.com?utm_source=goodeworkers">Netlify</a>
      </li>
      <li>{goodEWorkersText3}</li>
    </ul>
  </div>
</footer>
